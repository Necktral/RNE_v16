{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "certificate",
  "type": "object",
  "required": ["certificate_id", "proposal_id", "status", "evidence"],
  "properties": {
    "certificate_id": { "type": "string" },
    "proposal_id": { "type": "string" },
    "status": { "type": "string" },
    "evidence": { "type": "array" },
    "issued_at": { "type": "string" }
  },
  "additionalProperties": true
}

