# RNFE external reasoner — plantilla para Linux NATIVO (no WSL).
# El binario CUDA de llama.cpp y los GGUF los provee scripts/provision_llama_gpu.py,
# que además escribe un .env con estas variables ya resueltas. Este archivo documenta
# el layout nativo; ajustá RNFE_MODELS_ROOT a donde vivan tus modelos.

# Raíz de modelos/herramientas (portátil; sin /mnt/d de WSL).
export RNFE_MODELS_ROOT="$HOME/rnfe_models"

# Razonador (tier_3): GGUF del 7B + SHA256 esperado.
export RNFE_REASONING_GGUF="$RNFE_MODELS_ROOT/gguf/OpenThinker3-7B/OpenThinker3-7B-Q4_K_M.gguf"
export RNFE_EXPECTED_GGUF_SHA256=0b7344e4bf1c68fc40c4a10b14b9bd51f367423b8453d83544ea5bdbe08e7e5e

# Binario llama.cpp con soporte CUDA (prebuilt release o build local).
export RNFE_LLAMA_CLI_CUDA="$RNFE_MODELS_ROOT/tools/llama.cpp/build-cuda/bin/llama-cli"
export RNFE_LLAMA_CLI_CPU="$RNFE_MODELS_ROOT/tools/llama.cpp/build-cpu/bin/llama-cli"

# Backend GPU: -ngl 99 descarga todas las capas a la RTX 2070 (8GB alcanza para Q4_K_M).
export RNFE_EXTERNAL_REASONER_BACKEND=cuda
export RNFE_EXTERNAL_REASONER_NGL=99
export RNFE_EXTERNAL_REASONER_MAX_TOKENS=256
export RNFE_EXTERNAL_REASONER_PROMPT_STYLE=standard
export RNFE_EXTERNAL_REASONER_TIMEOUT_S=240
export RNFE_EXTERNAL_REASONER_STRUCTURED_OUTPUT_MODE=json_schema
export RNFE_EXTERNAL_REASONER_REASONING_BUDGET=0

# Habilitación en runtime (sin esto el perfil admitido nunca agenda ext_open_thinker).
export RNFE_EXTERNAL_REASONER_RUNTIME=1
export RNFE_ALLOW_EXTERNAL_REASONER=1
export RNFE_MAX_COMPUTE_TIER=tier_3_external

# Embeddings (tier_2): mismo binario llama.cpp con --embedding sobre un GGUF de embeddings.
export RNFE_MEMORY_EMBEDDINGS=llama
export RNFE_EMBEDDINGS_GGUF="$RNFE_MODELS_ROOT/gguf/embeddings/nomic-embed-text-v1.5.Q4_K_M.gguf"

# Cachés HF/torch portables (no /mnt/d).
export HF_HOME="$RNFE_MODELS_ROOT/cache/huggingface"
export HF_HUB_CACHE="$RNFE_MODELS_ROOT/cache/huggingface/hub"

# CUDA_ROOT solo si el binario llama.cpp necesita libs CUDA fuera del sistema; con un
# prebuilt estático normalmente no hace falta. En Linux nativo NO existe /usr/lib/wsl/lib.
# export CUDA_ROOT=/usr/local/cuda
