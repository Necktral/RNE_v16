{
  "context": {
    "fileName": [
      "GEMINI.md",
      "AGENTS.md",
      "ai/obsidian-mind/GEMINI.md",
      "ai/obsidian-mind/CLAUDE.md"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}/ai/obsidian-mind\" && GEMINI_PROJECT_DIR=\"$PWD\" node --disable-warning=ExperimentalWarning --experimental-strip-types \".claude/scripts/session-start.ts\"",
            "timeout": 30000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}/ai/obsidian-mind\" && GEMINI_PROJECT_DIR=\"$PWD\" node --disable-warning=ExperimentalWarning --experimental-strip-types \".claude/scripts/classify-message.ts\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}/ai/obsidian-mind\" && GEMINI_PROJECT_DIR=\"$PWD\" node --disable-warning=ExperimentalWarning --experimental-strip-types \".claude/scripts/validate-write.ts\"",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}/ai/obsidian-mind\" && GEMINI_PROJECT_DIR=\"$PWD\" node --disable-warning=ExperimentalWarning --experimental-strip-types \".claude/scripts/qmd-refresh.ts\"",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}/ai/obsidian-mind\" && GEMINI_PROJECT_DIR=\"$PWD\" node --disable-warning=ExperimentalWarning --experimental-strip-types \".claude/scripts/pre-compact.ts\"",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${GEMINI_PROJECT_DIR:-.}/ai/obsidian-mind\" && GEMINI_PROJECT_DIR=\"$PWD\" node --disable-warning=ExperimentalWarning --experimental-strip-types \".claude/scripts/stop-checklist.ts\"",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
